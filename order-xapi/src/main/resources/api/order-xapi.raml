#%RAML 1.0
# Order Experience API (order-xapi)
# Design Center & Exchange ready | API-Led Connectivity - Experience Layer
# Used by APIkit for flow scaffolding.

title: Order Experience API
description: |
  Consumer-facing API for Order Management System integration.
  Supports order creation, retrieval, listing, and status updates.
  Built on MuleSoft Anypoint Platform following API-Led Connectivity.
version: 1.0.0
baseUri: https://api.example.com/order-xapi/{version}

protocols: [ HTTPS ]
mediaType: application/json

documentation:
  - title: Overview
    content: |
      Use this API to create orders, retrieve order details, list orders with pagination,
      and update order lifecycle status. All operations require Basic Authentication.
  - title: Authentication
    content: |
      - **Basic Authentication**: Send `Authorization: Basic <base64(username:password)>` header.
      - Obtain credentials from your API consumer registration in Anypoint Platform.

uses:
  order-xapi-types: types/order-xapi-types.raml
  order-xapi-traits: traits/order-xapi-traits.raml

securedBy: [ basic ]

securitySchemes:
  basic:
    type: Basic Authentication
    description: Username and password sent in the Authorization header (Base64-encoded).

/health:
  displayName: Health
  description: Health check endpoint for API status visibility.
  get:
    displayName: Get API health
    description: Returns API name, version, and running status.
    is: [ order-xapi-traits.responses-401, order-xapi-traits.responses-500 ]
    responses:
      200:
        description: API health details
        body:
          application/json:
            example:
              apiName: order-xapi
              apiVersion: 1.0.0
              status: RUNNING

/orders:
  displayName: Orders
  description: Order collection and creation
  get:
    displayName: List orders
    description: Returns a paginated list of orders.
    is: [ order-xapi-traits.paginated, order-xapi-traits.responses-401, order-xapi-traits.responses-500 ]
    responses:
      200:
        description: List of orders
        body:
          application/json:
            type: order-xapi-types.OrderList
  post:
    displayName: Create order
    description: |
      Creates a new order after validating customer, inventory, and processing payment.
      Returns the created order with orderId and status.
    is: [ order-xapi-traits.responses-401, order-xapi-traits.responses-500 ]
    body:
      application/json:
        type: order-xapi-types.CreateOrderRequest
    responses:
      201:
        description: Order created successfully
        body:
          application/json:
            type: order-xapi-types.Order
      400:
        description: Invalid request (e.g. invalid customer, validation error)
        body:
          application/json:
            type: order-xapi-types.Error
      402:
        description: Payment failed
        body:
          application/json:
            type: order-xapi-types.Error
      409:
        description: Conflict (e.g. insufficient inventory)
        body:
          application/json:
            type: order-xapi-types.Error

  /{orderId}:
    displayName: Order by ID
    description: Single order resource
    uriParameters:
      orderId:
        type: string
        description: Unique order identifier
    get:
      displayName: Retrieve order
      description: Returns order details by order ID.
      is: [ order-xapi-traits.responses-401, order-xapi-traits.responses-500 ]
      responses:
        200:
          description: Order details
          body:
            application/json:
              type: order-xapi-types.Order
        404:
          description: Order not found
          body:
            application/json:
              type: order-xapi-types.Error

    /status:
      displayName: Order status
      description: Update order lifecycle status
      patch:
        displayName: Update order status
        description: Updates the order lifecycle status (e.g. SHIPPED, DELIVERED).
        is: [ order-xapi-traits.responses-401, order-xapi-traits.responses-500 ]
        body:
          application/json:
            type: order-xapi-types.UpdateOrderStatusRequest
        responses:
          200:
            description: Status updated; returns updated order
            body:
              application/json:
                type: order-xapi-types.Order
          400:
            description: Invalid request (e.g. invalid status value)
            body:
              application/json:
                type: order-xapi-types.Error
          404:
            description: Order not found
            body:
              application/json:
                type: order-xapi-types.Error
